<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:micro="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             xmlns:microcharts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             NavigationPage.HasNavigationBar="True"
             x:Class="MauiApp3.Views.MainPage"
             BackgroundColor="White">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="📷 Tara" Clicked="OnScanReceiptClicked" Priority="0" Order="Primary"/>
        <ToolbarItem Text="🖼️ Galeri" Clicked="OnPickPhotoClicked" Priority="1" Order="Primary"/>
        <ToolbarItem Text="⚙️ Ayarlar" Clicked="OnSettingsClicked" Priority="2" Order="Secondary"/>
    </ContentPage.ToolbarItems>

    <Grid ColumnDefinitions="*, Auto, Auto" 
      Padding="20,40,20,10" 
      BackgroundColor="#F8F9FA">

        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
            <Label Text="Merhaba 👋" FontSize="14" TextColor="Gray"/>
            <Label Text="BUÜ Finans Asistanı" FontSize="18" FontAttributes="Bold" TextColor="#1C1C1E"/>
        </VerticalStackLayout>

        <ImageButton Grid.Column="1" 
                 Source="camera_icon.png" 
                 Clicked="OnScanReceiptClicked"
                 HeightRequest="30" WidthRequest="30"
                 Margin="0,0,15,0"
                 VerticalOptions="Center"/>

        <ImageButton Grid.Column="2" 
                 Source="gallery_icon.png" 
                 Clicked="OnPickPhotoClicked"
                 HeightRequest="30" WidthRequest="30"
                 VerticalOptions="Center"/>
        
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="15" BackgroundColor="White">
                <Frame CornerRadius="12" Padding="5" BackgroundColor="#F2F2F7" HasShadow="False" BorderColor="#D1D1D6">
                    <VerticalStackLayout Padding="10">
                        <Label Text="Üniversiteniz" FontSize="11" TextColor="Gray"/>
                        <Entry x:Name="UniEntry" Placeholder="Üniversite adını girin..." TextColor="Black" FontSize="16"/>
                    </VerticalStackLayout>
                </Frame>

                <Border BackgroundColor="White" 
                    Stroke="#2196F3" 
                    StrokeShape="RoundRectangle 10" 
                    Padding="5" 
                    HeightRequest="50">
                    <Picker x:Name="TimeFilterPicker" 
                        Title="Filtrele" 
                        SelectedIndexChanged="OnFilterChanged">
                        <Picker.Items>
                            <x:String>Bugün</x:String>
                            <x:String>Bu Hafta</x:String>
                            <x:String>Bu Ay</x:String>
                        </Picker.Items>
                    </Picker>
                </Border>

                <microcharts:ChartView x:Name="MyChartView" HeightRequest="220" BackgroundColor="White"/>
                
                <VerticalStackLayout Spacing="5" Margin="0,5">
                        <Label Text="Bugünkü Bütçeniz" FontSize="13" HorizontalOptions="Center" TextColor="#3A3A3C"/>
                    <Slider x:Name="BudgetSlider" Minimum="100" Maximum="10000" MinimumTrackColor="#2196F3" MaximumTrackColor="#E5E5EA" ThumbColor="#2196F3" ValueChanged="OnSliderValueChanged"/>
                    <Entry x:Name="BudgetEntry" Grid.Column="1" Text="100" Keyboard="Numeric" HorizontalTextAlignment="Center" TextChanged="OnBudgetEntryChanged" BackgroundColor="Black"/>
                        <Label x:Name="BudgetValueLabel" Text="100 TL" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2196F3"/>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, Auto" HeightRequest="230" Margin="0,10">
                        <Grid Grid.Column="0">
                        <micro:ChartView x:Name="ExpenseChartView" BackgroundColor="White" HeightRequest="220" WidthRequest="220"/>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="True" Spacing="0">
                            <Label Text="Toplam" FontSize="10" TextColor="Gray" CharacterSpacing="1" HorizontalOptions="Center" FontAttributes="Bold"/>
                                <Label x:Name="TotalExpenseLabel" Text="0 ₺" FontSize="24" FontAttributes="Bold" TextColor="Black" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                        <ScrollView Grid.Column="1" WidthRequest="130">
                            <VerticalStackLayout x:Name="MiniExpenseList" Spacing="5" Padding="5" />
                        </ScrollView>
                    </Grid>

                    <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" Color="#3498DB" HorizontalOptions="Center"/>

                    <Button x:Name="AnalyzeButton" Text="📊 Analiz Et ve Tavsiye Al" Clicked="OnAnalyzeClicked" BackgroundColor="#3498DB" TextColor="White" CornerRadius="12" HeightRequest="50"/>
                    <Button Text="➕ Harcama Ekle" Clicked="OnAddExpenseClicked" BackgroundColor="#4CAF50" TextColor="White" CornerRadius="12" HeightRequest="50" />

                    <Frame x:Name="MiniBoard" CornerRadius="15" BackgroundColor="#F9F9F9" HasShadow="True" BorderColor="#E5E5EA">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBoardTapped" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="BoardTitle" Text="📌 Finansal Özet (Tıkla ve Gör)" FontAttributes="Bold" FontSize="15" TextColor="#1C1C1E"/>

                            <VerticalStackLayout x:Name="DetailsLayout" IsVisible="False" Spacing="10">
                                <Label Text="Günün Haberleri" FontAttributes="Bold" TextColor="#2196F3" FontSize="13"/>
                            <Label x:Name="NewsLabel" Text="Haberler yükleniyor..." TextColor="#444" FontSize="13" MaxLines="4" LineBreakMode="TailTruncation" />

                                <BoxView HeightRequest="1" Color="#DDD"/>

                                <Label Text="Yatırım ve Tasarruf Tavsiyesi" FontAttributes="Bold" TextColor="#2196F3" FontSize="13"/>
                            <Label x:Name="AdviceLabel" Text="Tavsiyeler buraya gelecek..." TextColor="#444" FontSize="13" FontAttributes="Italic" MaxLines="4" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Frame>

                    <Label Text="📜 Geçmiş Analizler" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" Margin="0,15,0,5" />

                    <CollectionView x:Name="HistoryList"
                                SelectionMode="Single"
                                SelectionChanged="OnHistorySelectionChanged"
                                HeightRequest="300"
                                    VerticalOptions="FillAndExpand"
                                EmptyView="Henüz bir analiz bulunmuyor.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 10" BackgroundColor="#F8F9FA" Margin="0,4" Padding="12" Stroke="#E0E0E0">
                                    <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label Text="{Binding KayitTarihi, StringFormat='{0:dd MMM yyyy - HH:mm}'}" FontSize="10" TextColor="Gray" />
                                            <Label Text="{Binding tavsiye}" FontSize="13" TextColor="Black" MaxLines="2" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="〉" FontSize="18" TextColor="#BDBDBD" VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </ContentPage>
    