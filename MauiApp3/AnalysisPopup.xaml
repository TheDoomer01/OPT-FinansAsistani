<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="MauiApp3.Views.AnalysisPopup">

    <Border BackgroundColor="White" 
            StrokeShape="RoundRectangle 20" 
            Padding="20" 
            WidthRequest="350" 
            HeightRequest="500">

        <!-- Ana taşıyıcı: Grid kullanarak butonun altta sabit kalmasını sağlıyoruz -->
        <Grid RowDefinitions="Auto, *, Auto" RowSpacing="15">

            <!-- ÜST: Başlık -->
            <Label Grid.Row="0" Text="🤖 Gemini Finans Analizi" 
               FontSize="20" FontAttributes="Bold" 
               HorizontalOptions="Center" TextColor="Black"/>

            <!-- ORTA: Kaydırılabilir Alan (ScrollView) -->
            <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Always">
                <VerticalStackLayout Spacing="10">
                    <Label Text="💡 Tavsiye" FontAttributes="Bold" TextColor="#3498DB"/>
                    <Label x:Name="AdviceLabel" TextColor="Black" LineBreakMode="WordWrap"/>

                    <BoxView HeightRequest="1" Color="Silver" Margin="0,10"/>

                    <Label Text="📢 Haberler" FontAttributes="Bold" TextColor="#E67E22"/>
                    <Label x:Name="NewsLabel" TextColor="Black" LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </ScrollView>

            <!-- ALT: Kapat Butonu (Kaydırmadan etkilenmez, hep altta durur) -->
            <Button Grid.Row="2" Text="Kapat" Clicked="OnCloseClicked" 
                BackgroundColor="#2C3E50" TextColor="White" CornerRadius="10"/>
        </Grid>
    </Border>
</toolkit:Popup>