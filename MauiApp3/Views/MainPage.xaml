<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:micro="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
    x:Class="MauiApp3.Views.MainPage"
    BackgroundColor="#F5F7FA"
    NavigationPage.HasNavigationBar="True">

    <!-- TOOLBAR -->
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="📷 Tara" Clicked="OnScanReceiptClicked"/>
        <ToolbarItem Text="🖼️ Galeri" Clicked="OnPickPhotoClicked"/>
        <ToolbarItem Text="⚙️ Ayarlar" Clicked="OnSettingsClicked"/>
    </ContentPage.ToolbarItems>

    <!-- MAIN SCROLL -->
    <ScrollView>
        <VerticalStackLayout Padding="16, 16, 16, 100" Spacing="18">

            <!-- HEADER -->
            <Grid ColumnDefinitions="*,Auto,Auto">
                <VerticalStackLayout>
                    <Label Text="Merhaba 👋" FontSize="14" TextColor="Gray"/>
                    <Label Text="ÖPT Finans Asistanı" FontSize="24" FontAttributes="Bold" TextColor="#1C1C1E"/>
                </VerticalStackLayout>

                <ImageButton Grid.Column="1" Source="camera_icon.png" HeightRequest="28" WidthRequest="28" Margin="0,0,12,0" BackgroundColor="Transparent" Clicked="OnScanReceiptClicked"/>
                <ImageButton Grid.Column="2" Source="gallery_icon.png" HeightRequest="28" WidthRequest="28" BackgroundColor="Transparent" Clicked="OnPickPhotoClicked"/>
            </Grid>

            <!-- ÜNİVERSİTE -->
            <Frame CornerRadius="14" HasShadow="False" BorderColor="#E0E0E0" BackgroundColor="White" Padding="14">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Üniversiteniz" FontSize="12" TextColor="Gray"/>
                    <Entry x:Name="UniEntry" Placeholder="Üniversite adını girin..." FontSize="16" TextColor="Black"/>
                </VerticalStackLayout>
            </Frame>

            <!-- FILTER -->
            <Border Stroke="#2196F3" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="10">
                <Picker x:Name="TimeFilterPicker" Title="Filtrele" TitleColor="#2196F3" SelectedIndexChanged="OnFilterChanged">
                    <Picker.Items>
                        <x:String>Bugün</x:String>
                        <x:String>Bu Hafta</x:String>
                        <x:String>Bu Ay</x:String>
                    </Picker.Items>
                </Picker>
            </Border>

            <!-- Bugün harcama yoksa çıkacak olan gizli mesaj -->
            <Label x:Name="EmptyDataLabel" 
            Text="Bugün henüz hiçbir harcama yapmadınız. Harika gidiyorsunuz! 🎉" 
            IsVisible="False" 
            HorizontalOptions="Center" 
            VerticalOptions="Center" 
            HorizontalTextAlignment="Center"
            FontSize="16" 
            TextColor="Gray" 
            Margin="0,40,0,40" />

            <!-- MAIN CHART -->
            <Frame CornerRadius="16" BackgroundColor="White" BorderColor="#ECECEC" HasShadow="False" Padding="10">
                <micro:ChartView x:Name="MyChartView" HeightRequest="220"/>
            </Frame>

            <!-- BÜTÇE (DÜZELTİLEN KISIM) -->
            <Frame CornerRadius="16" BackgroundColor="White" BorderColor="#ECECEC" HasShadow="False" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Bugünkü Bütçeniz" HorizontalOptions="Center" FontSize="15" TextColor="#444"/>

                    <Slider x:Name="BudgetSlider" Minimum="100" Maximum="10000" MinimumTrackColor="#2196F3" MaximumTrackColor="#E5E5EA" ThumbColor="#2196F3" ValueChanged="OnSliderValueChanged"/>

                    <Border Stroke="#D1D1D6" StrokeShape="RoundRectangle 10" Padding="10">
                        <!-- TextColor eklendi ve TextChanged olayı bağlandı -->
                        <Entry x:Name="BudgetEntry" 
                               Keyboard="Numeric" 
                               HorizontalTextAlignment="Center" 
                               TextColor="Black"
                               TextChanged="OnBudgetEntryChanged"
                               Text="100"/>
                    </Border>

                    <Label x:Name="BudgetValueLabel" Text="100 TL" HorizontalOptions="Center" FontSize="30" FontAttributes="Bold" TextColor="#2196F3"/>
                </VerticalStackLayout>
            </Frame>

            <!-- EXPENSE CHART (DÜZELTİLMİŞ VE FERAH TASARIM) -->
            <Frame CornerRadius="16" BackgroundColor="White" BorderColor="#ECECEC" HasShadow="False" Padding="15">
                <!-- Ana Taşıyıcı: Her şeyi alt alta dizer -->
                <VerticalStackLayout Spacing="10">

                    <!-- ÜST KISIM: Grafik ve Liste Yan Yana -->
                    <Grid ColumnDefinitions="4*, 6*">

                        <!-- SOL SÜTUN (Sütun 0): Sadece Grafik Alanı -->
                        <Grid Grid.Column="0" VerticalOptions="Center" Margin="0,0,0,10">
                            <micro:ChartView x:Name="ExpenseChartView" HeightRequest="160" VerticalOptions="Center"/>

                            <!-- Ortadaki Toplam Yazısı -->
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="True">
                                <Label Text="Toplam" FontSize="11" HorizontalOptions="Center" TextColor="Gray"/>
                                <Label x:Name="TotalExpenseLabel" Text="0 ₺" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" TextColor="Black"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- SAĞ SÜTUN (Sütun 1): Kaydırılabilir Harcama Listesi -->
                        <ScrollView Grid.Column="1" Margin="10,0,0,0" HeightRequest="220" VerticalScrollBarVisibility="Default">
                            <VerticalStackLayout x:Name="MiniExpenseList" Spacing="8" Padding="5"/>
                        </ScrollView>
                    </Grid>

                    <!-- Araya ince bir ayırıcı çizgi -->
                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="0,5"/>

                    <!-- ALT KISIM: Gösterge Alanı (Renkli Kategori İsimleri) -->
                    <!-- Bu alan artık Grid'in dışında olduğu için Android'de grafik üstüne binmez -->
                    <FlexLayout x:Name="ChartLegendLayout" 
                    Wrap="Wrap" 
                    JustifyContent="Center" 
                    AlignItems="Center" 
                    Margin="0,5,0,0"
                    Padding="5" />

                </VerticalStackLayout>
            </Frame>
            
            <!-- LOADING -->
            <ActivityIndicator x:Name="LoadingIndicator" IsVisible="False" IsRunning="False" Color="#2196F3" HorizontalOptions="Center"/>

            <!-- BUTTONS -->
            <HorizontalStackLayout Spacing="10">
                <Button x:Name="AnalyzeButton" Text="📊 Analiz" HorizontalOptions="FillAndExpand" HeightRequest="52" CornerRadius="14" BackgroundColor="#2196F3" TextColor="White" Clicked="OnAnalyzeClicked"/>
                <Button Text="➕ Ekle" HorizontalOptions="FillAndExpand" HeightRequest="52" CornerRadius="14" BackgroundColor="#4CAF50" TextColor="White" Clicked="OnAddExpenseClicked"/>
            </HorizontalStackLayout>

            <!-- FINANCIAL BOARD -->
            <Frame x:Name="MiniBoard" CornerRadius="16" BackgroundColor="White" BorderColor="#ECECEC" HasShadow="False" Padding="16">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBoardTapped"/>
                </Frame.GestureRecognizers>
                <VerticalStackLayout Spacing="14">
                    <Label x:Name="BoardTitle" Text="📌 Finansal Özet" FontSize="16" FontAttributes="Bold" TextColor="#1C1C1E"/>
                    <VerticalStackLayout x:Name="DetailsLayout" IsVisible="False" Spacing="12">
                        <Label Text="Günün Haberleri" FontAttributes="Bold" TextColor="#2196F3"/>
                        <Label x:Name="NewsLabel" Text="Haberler yükleniyor..." FontSize="13" TextColor="#444"/>
                        <BoxView HeightRequest="1" Color="#EAEAEA"/>
                        <Label Text="Yatırım Tavsiyesi" FontAttributes="Bold" TextColor="#2196F3"/>
                        <Label x:Name="AdviceLabel" Text="Tavsiyeler..." FontSize="13" TextColor="#444"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Label Text="📜 Geçmiş Analizler" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" Margin="0,10,0,5"/>

            <!-- Açılır/Kapanır Yapı İçin Kapsayıcı Grid -->
            <Grid RowDefinitions="Auto, Auto">

                <!-- 1. KISIM: Kaydırılabilir Liste (Başlangıçta 220 piksel ile sınırlandırdık) -->
                <!-- x:Name="HistoryScrollView" ekledik ki C# üzerinden boyunu uzatıp kısaltabilelim -->
                <ScrollView x:Name="HistoryScrollView" Grid.Row="0" HeightRequest="220" VerticalScrollBarVisibility="Never">

                    <!-- Senin Orijinal Listen (Hiçbir bağlamasını bozmadık) -->
                    <VerticalStackLayout x:Name="HistoryList" BindableLayout.ItemsSource="{Binding HistoryItems}" Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Frame CornerRadius="12" Padding="12" Margin="0,2" BackgroundColor="White" BorderColor="#EAEAEA" HasShadow="False">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectHistoryCommand}" CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout>
                                            <Label Text="{Binding KayitTarihi, StringFormat='{0:dd MMM yyyy - HH:mm}'}" FontSize="11" TextColor="Gray"/>
                                            <Label Text="{Binding tavsiye}" FontSize="14" TextColor="Black" MaxLines="2"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="›" FontSize="22" VerticalOptions="Center" TextColor="#BDBDBD"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                </ScrollView>

                <!-- 2. KISIM: Genişlet/Daralt Etiketi (Tıklanabilir Buton Gibi Davranan Yazı) -->
                <Label x:Name="HistoryExpandLabel" 
                       Grid.Row="1" 
                       Text="Daha Fazla Göster ▼" 
                       FontSize="12" 
                       TextColor="#3498DB" 
                       HorizontalOptions="Center" 
                       Margin="0,8,0,10" 
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <!-- Tıklandığında C# tarafındaki metodu tetikler -->
                        <TapGestureRecognizer Tapped="OnHistoryExpandTapped" />
                    </Label.GestureRecognizers>
                </Label>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>